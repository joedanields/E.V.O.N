# ═══════════════════════════════════════════════════════════
#  E.V.O.N. — Environment Configuration
#  Copy to .env and adjust values as needed.
# ═══════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── SEC-002: API Authentication ───────────────────────────
# Leave empty for local dev (no auth). Set a strong key for production.
API_KEY=

# ── Whisper STT ───────────────────────────────────────────
# Models: tiny | base | small | medium | large-v3
# Use "large-v3" for best accuracy on RTX 3090
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# ── Ollama LLM ────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=120

# ── Piper TTS ─────────────────────────────────────────────
# Download models from: https://github.com/rhasspy/piper/releases
# PIPER_MODEL_PATH=models/piper/en_US-lessac-medium.onnx
# PIPER_CONFIG_PATH=models/piper/en_US-lessac-medium.onnx.json
TTS_SAMPLE_RATE=22050
TTS_CACHE_SIZE=100

# ── Database ──────────────────────────────────────────────
# DATABASE_URL=sqlite+aiosqlite:///data/evon.db

# ── QUALITY-004: Tuning ──────────────────────────────────
HISTORY_LIMIT=20
TITLE_MAX_LENGTH=100
